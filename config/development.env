# 
# Development Environment Variables File
#

# --- Project Information --- #
PROJECT_NAME=dfst-project  

# --- Docker Images --- #
PROJECT_BACKEND_HTTP_SERVER_IMAGE=python:3.14          # Python3 (Flask)
PROJECT_BACKEND_WEBSOCKETS_SERVER_IMAGE=python:3.14             # Python3 (Flask-SocketIO)
PROJECT_BACKEND_QUEUE_SERVER_IMAGE=redis:7.2-alpine                     # Redis
PROJECT_BACKEND_QUEUE_PROCESSOR_IMAGE=python:3.14-slim                  # Python-RQ 
PROJECT_BACKEND_DATABASE_IMAGE=mongo:8.0                                # MongoDB
PROJECT_BACKEND_CACHE_SERVER_IMAGE=redis:7.2-alpine                     # Redis 
PROJECT_FRONTEND_WEB_IMAGE=node:20-alpine                               # NodeJS (Vite + Vue)
PROJECT_FRONTEND_MOBILE_IMAGE=node:20-alpine                            # NodeJS (Vite + Vue)

# --- Project Domain Name Extensions--- #
PROJECT_DOMAIN_EXTENSION=.local
PROJECT_BACKEND_HTTP_SERVER_DOMAIN="api.${PROJECT_NAME}${PROJECT_DOMAIN_EXTENSION}"
PROJECT_BACKEND_CACHE_SERVER_DOMAIN="ws.${PROJECT_NAME}${PROJECT_DOMAIN_EXTENSION}"
PROJECT_BACKEND_CACHE_SERVER_DOMAIN="db.${PROJECT_NAME}${PROJECT_DOMAIN_EXTENSION}"
PROJECT_BACKEND_CACHE_SERVER_DOMAIN="cache.${PROJECT_NAME}${PROJECT_DOMAIN_EXTENSION}"
PROJECT_FRONTEND_WEB_DOMAIN="${PROJECT_NAME}${PROJECT_DOMAIN_EXTENSION}"
